{
    "name": "L8 Best Practices",
    "dockerComposeFile": [
        "../../docker-compose.yml"
    ], // locate the docker compose file
    "service": "best-practices-dev", // locate the service used in the docker compose file
    "shutdownAction": "none",
    "workspaceFolder": "/workspace/train-and-deploy", // locate the root folder for this service
    "customizations": { // define which extensions we will need for our dev env
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.pylint",
                "ms-python.black-formatter",
                "ms-python.isort"
            ]
        }
    }
}